# Firebase
# Apenas o Project ID é necessário.
# As credenciais são gerenciadas via ADC:
#   - Local:     gcloud auth application-default login
#   - Cloud Run: Service Account atribuída via IAM (automático)
FIREBASE_PROJECT_ID=app-name
# Database customizado (omita para usar o "(default)")
# FIREBASE_DATABASE_ID=onelink-db

# Servidor
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------
# GCP / Cloud Run
# ---------------------------------------------------------------
# Build & deploy manual:
#   gcloud builds submit --config=cloudbuild.yaml \
#     --substitutions=_REGION=us-central1,_SERVICE_NAME=onelink-server,_REPOSITORY=onelink
